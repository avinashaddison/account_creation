modules = ["nodejs-20", "web", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["glib", "nss", "nspr", "atk", "cups", "dbus", "at-spi2-atk", "at-spi2-core", "expat", "xorg.libX11", "xorg.libXcomposite", "xorg.libXdamage", "xorg.libXext", "xorg.libXfixes", "xorg.libXrandr", "xorg.libxcb", "mesa", "gtk3", "pango", "cairo", "alsa-lib", "xorg.libxshmfence", "libxkbcommon", "xvfb-run", "xorg.xorgserver"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 24678
externalPort = 3000

[env]
PORT = "5000"

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["node", "./dist/index.cjs"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx playwright install chromium --quiet 2>/dev/null; NODE_ENV=development npx tsx server/index.ts"
waitForPort = 5000

[agent]
stack = "MOCKUP_JS"
mockupState = "FULLSTACK"
expertMode = true

[userenv]

[userenv.shared]
LA28_PROXY_URL = "wss://brd-customer-hl_86b34e68-zone-scraping_browser1:xov21cay1g29@brd.superproxy.io:9222"
NEON_DATABASE_URL = "postgresql://neondb_owner:npg_qiZSW7d0TJoB@ep-winter-base-an9kkwgp-pooler.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000
